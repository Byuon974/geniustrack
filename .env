# ╔══════════════════════════════════════════════════════════════════╗
# ║  Configuration GeniusLab — valeurs par défaut prêtes à l'emploi.  ║
# ║  En dev/Docker, ce fichier suffit : aucune autre config requise.  ║
# ║  En production, surchargez via un .env.local (NON versionné).     ║
# ╚══════════════════════════════════════════════════════════════════╝

###> symfony/framework-bundle ###
APP_ENV=dev
# Secret de l'application : change-le en production (chaîne aléatoire).
APP_SECRET=change_this_secret_in_production_0123456789abcdef
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Connexion PostgreSQL. Les valeurs correspondent au service "database" du compose.
# Le compose.yaml fournit déjà DATABASE_URL ; cette ligne sert de repli hors Docker.
DATABASE_URL="postgresql://app:!ChangeMe!@database:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Transport asynchrone : table Doctrine (aucun service externe requis).
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# En dev, les mails ne partent pas réellement (null). En prod, mettez un vrai DSN
# (ex. smtp://user:pass@smtp.example.com:587).
MAILER_DSN=null://null
###< symfony/mailer ###

###> geniuslab ###
# Jeton du flux iCal du planning (BF_3.1). VIDE = abonnement désactivé (le reste
# de l'app fonctionne normalement). Pour l'activer : openssl rand -hex 24
CALENDRIER_ICAL_TOKEN=
###< geniuslab ###
