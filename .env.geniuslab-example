# Variables GeniusLab pour Docker — copier vers .env et ajuster.
# Les défauts du compose.yaml fonctionnent en dev sans ce fichier.

POSTGRES_DB=geniuslab
POSTGRES_USER=geniuslab
POSTGRES_PASSWORD=changeme-en-prod
POSTGRES_VERSION=16

# Ports (changer si 80/443 déjà pris en local)
# HTTP_PORT=8080
# HTTPS_PORT=8443

# Jeton secret du flux iCal du planning (BF_3.1).
# GÉNÉRER une valeur aléatoire en production, ex. : openssl rand -hex 24
# Quiconque a ce jeton peut consulter le planning : gardez-le confidentiel.
CALENDRIER_ICAL_TOKEN=changez-moi-en-production
