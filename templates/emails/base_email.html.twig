<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"></head>
<body style="font-family: Arial, sans-serif; color: #1a2630; line-height: 1.5;">
    <div style="max-width: 560px; margin: 0 auto; padding: 24px;">
        <div style="background: #1d4e6f; color: #fff; padding: 16px 24px; border-radius: 8px 8px 0 0;">
            <strong style="font-size: 18px;">GeniusLab</strong>
        </div>
        <div style="border: 1px solid #dce3e9; border-top: none; padding: 24px; border-radius: 0 0 8px 8px;">
            {% block content %}{% endblock %}
        </div>
        <p style="color: #5b6b78; font-size: 12px; margin-top: 16px;">
            FabLab du Campus CCI Nord. Message automatique, ne pas répondre.
        </p>
    </div>
</body>
</html>
