{% extends 'base.html.twig' %}
{% block title %}{{ projet.titre }}{% endblock %}
{% block fil_ariane %}{{ include('components/fil_ariane.html.twig', {segments: [
    {libelle: 'Mon espace', url: null},
    {libelle: 'Mes projets', url: path('projet_index')},
    {libelle: projet.titre, url: null}
]}) }}{% endblock %}
{% block body %}
{# Sessions planifiées (statut « planifiee ») : base des compteurs de synthèse
   et de la liste. Calculées une fois ici pour éviter de re-filtrer. Une session
   est un créneau de groupe (une à plusieurs machines en parallèle). #}
{% set planifies = projet.sessions|filter(s => s.statut.value == 'planifiee') %}
{% set nbRealisations = projet.sessions|filter(
    s => s.type.value == 'realisation' and s.statut.value not in ['annulee', 'reportee']
)|length %}

<div class="page-header">
    <h1>{{ projet.titre }}</h1>
    {{ include('components/badge.html.twig', {couleur: projet.statut.couleur, label: projet.statut.libelle}) }}
</div>

<div class="prevision-carte">
    <p>{{ projet.description }}</p>
    <p class="cat">{{ projet.type.libelle }}, machines :
       {% for m in projet.machines %}{{ include('components/badge.html.twig', {couleur: 'blue', label: m.nom}) }} {% endfor %}
    </p>

    {% set plansModifiables = projet.statut.value in ['brouillon', 'en_attente'] %}

    {% if projet.plans is not empty %}
        <div class="plans-list">
            <strong>Plans importés :</strong>
            <ul>
                {% for plan in projet.plans %}
                    <li class="plan-item">
                        <a href="{{ path('plan_telecharger', {id: plan.id}) }}">{{ plan.nomOriginal }}</a>
                        {% if plansModifiables %}
                            <form method="post" action="{{ path('plan_supprimer', {id: plan.id}) }}" class="plan-item__retrait"
                                  data-controller="confirm"
                                  data-confirm-message-value="Le fichier « {{ plan.nomOriginal }} » sera retiré de la demande."
                                  data-confirm-titre-value="Retirer ce fichier ?"
                                  data-confirm-variante-value="danger" data-confirm-libelle-value="Retirer">
                                <input type="hidden" name="_token" value="{{ csrf_token('plan_supprimer' ~ plan.id) }}">
                                <button type="submit" class="btn btn--sm btn--ghost">Retirer</button>
                            </form>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if plansModifiables %}
        <form method="post" action="{{ path('plan_ajouter', {id: projet.id}) }}" enctype="multipart/form-data" class="plan-ajout-form">
            <input type="hidden" name="_token" value="{{ csrf_token('plan_ajouter' ~ projet.id) }}">
            {{ include('components/upload.html.twig', {
                input_html: '<input type="file" name="plans[]" multiple data-file-upload-target="input" data-action="change->file-upload#surChangement">',
                label: 'Ajouter des fichiers',
                formats: 'STL, OBJ, PDF, SVG, ZIP, JPEG, PNG, WebP · 10 fichiers max, 25 Mo chacun, 80 Mo au total',
                bouton: 'Ajouter'
            }) }}
        </form>
    {% endif %}

    {% if projet.statut.value == 'brouillon' %}
        {# Brouillon : demande non soumise (création interrompue ou rétractation).
           L'étudiant la complète puis la soumet, ou l'abandonne. #}
        <div class="projet-retracter">
            <p class="projet-retracter__intro">Cette demande est en brouillon. Elle n'est pas encore soumise à validation.</p>
            <div class="projet-retracter__actions">
                <form method="post" action="{{ path('projet_soumettre', {id: projet.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('soumettre' ~ projet.id) }}">
                    <button type="submit" class="btn btn--primary">Soumettre la demande</button>
                </form>
                <form method="post" action="{{ path('projet_supprimer', {id: projet.id}) }}"
                      data-controller="confirm"
                      data-confirm-message-value="La demande sera définitivement supprimée. Cette action est irréversible."
                      data-confirm-titre-value="Supprimer cette demande ?"
                      data-confirm-variante-value="danger" data-confirm-libelle-value="Supprimer">
                    <input type="hidden" name="_token" value="{{ csrf_token('supprimer' ~ projet.id) }}">
                    <button type="submit" class="btn btn--refus">Supprimer la demande</button>
                </form>
            </div>
        </div>
    {% endif %}

    {% if projet.statut.value == 'refuse' %}
        <div class="alert alert--error">
            <strong>Projet refusé.</strong> {{ projet.motifRefus }}
        </div>
        <form method="post" action="{{ path('projet_resoumettre', {id: projet.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('resoumettre' ~ projet.id) }}">
            <button type="submit" class="btn btn--primary">Corriger et resoumettre</button>
        </form>
    {% endif %}

    {% if projet.statut.value == 'en_attente' %}
        {# Rétractation d'une demande encore en attente : corriger (retour en
           brouillon) ou supprimer définitivement. #}
        <div class="projet-retracter">
            <p class="projet-retracter__intro">Cette demande est en attente de validation. Vous pouvez encore la retirer :</p>
            <div class="projet-retracter__actions">
                <form method="post" action="{{ path('projet_retracter', {id: projet.id}) }}"
                      data-controller="confirm"
                      data-confirm-message-value="La demande repassera en brouillon. Vous pourrez la corriger puis la resoumettre."
                      data-confirm-titre-value="Rétracter pour corriger ?"
                      data-confirm-libelle-value="Rétracter">
                    <input type="hidden" name="_token" value="{{ csrf_token('retracter' ~ projet.id) }}">
                    <button type="submit" class="btn btn--primary">Rétracter pour corriger</button>
                </form>
                <form method="post" action="{{ path('projet_supprimer', {id: projet.id}) }}"
                      data-controller="confirm"
                      data-confirm-message-value="La demande sera définitivement supprimée. Cette action est irréversible."
                      data-confirm-titre-value="Supprimer cette demande ?"
                      data-confirm-variante-value="danger" data-confirm-libelle-value="Supprimer">
                    <input type="hidden" name="_token" value="{{ csrf_token('supprimer' ~ projet.id) }}">
                    <button type="submit" class="btn btn--refus">Supprimer la demande</button>
                </form>
            </div>
        </div>
    {% endif %}

    {% if projet.statut.value in ['valide', 'en_cours'] %}
        <a href="{{ path('reservation_creer', {id: projet.id}) }}" class="btn btn--primary">Réserver un créneau</a>
    {% endif %}
</div>

{% if planifies is not empty %}
    {# Synthèse : rend visibles des informations métier déjà calculées côté
       serveur mais jamais montrées (quota de sessions, prochaine échéance). #}
    {% set prochaine = planifies|sort((a, b) => a.dateDebut <=> b.dateDebut)|first %}
    {% set joursCourts = {1: 'lun.', 2: 'mar.', 3: 'mer.', 4: 'jeu.', 5: 'ven.', 6: 'sam.', 7: 'dim.'} %}
    <div class="resa-synthese">
        <div class="resa-stat">
            <span class="resa-stat__label">Créneaux planifiés</span>
            <span class="resa-stat__valeur">{{ planifies|length }}</span>
        </div>
        <div class="resa-stat">
            <span class="resa-stat__label">Prochaine session</span>
            <span class="resa-stat__valeur resa-stat__valeur--date">
                {{ joursCourts[prochaine.dateDebut|date('N')] }} {{ prochaine.dateDebut|date('d/m') }}
                <small>{{ prochaine.dateDebut|date('H\\hi') }}</small>
            </span>
        </div>
        <div class="resa-stat">
            <span class="resa-stat__label">Sessions de réalisation</span>
            <span class="resa-stat__valeur">{{ nbRealisations }} <small>/ {{ constant('App\\Entity\\SessionReservation::MAX_SESSIONS_REALISATION') }}</small></span>
        </div>
    </div>
{% endif %}

{% if projet.sessions is not empty %}
    <div class="resa-liste-tete">
        <h2 class="section-title">Mes créneaux</h2>
        {% if projet.statut.value in ['valide', 'en_cours'] %}
            <a href="{{ path('reservation_creer', {id: projet.id}) }}" class="resa-liste-ajout">+ Réserver d'autres créneaux</a>
        {% endif %}
    </div>

    <div class="resa-cartes">
        {% for s in projet.sessions %}
            <div class="resa-carte resa-carte--{{ s.statut.value }}">
                <div class="resa-carte__icone" aria-hidden="true">
                    {{ include('components/icon.html.twig', {name: 'wrench'}) }}
                </div>
                <div class="resa-carte__corps">
                    <div class="resa-carte__machine">
                        {{ s.machines|map(m => m.nom)|join(', ') }}
                        <span class="resa-carte__type">· {{ s.type.libelle }}</span>
                    </div>
                    <div class="resa-carte__quand">
                        {{ s.dateDebut|date('d/m/Y') }} · {{ s.dateDebut|date('H\\hi') }} → {{ s.dateFin|date('H\\hi') }}
                        · {{ s.nbPersonnes }} pers.
                    </div>
                </div>
                {% set varianteStatut = {
                    'planifiee': 'info', 'effectuee': 'succes',
                    'annulee': 'danger', 'reportee': 'neutre'
                } %}
                {{ include('components/badge.html.twig', {
                    variante: varianteStatut[s.statut.value]|default('neutre'),
                    label: s.statut.libelle
                }) }}
                {% if s.statut.value == 'planifiee' %}
                    <div class="resa-carte__actions">
                        <a href="{{ path('reservation_reporter_page', {id: s.id}) }}" class="btn btn--sm">Reporter</a>
                        <form method="post" action="{{ path('reservation_annuler', {id: s.id}) }}"
                              data-controller="confirm" data-confirm-message-value="Ce créneau de réservation sera annulé."
                              data-confirm-titre-value="Annuler ce créneau ?" data-confirm-variante-value="danger"
                              data-confirm-libelle-value="Annuler le créneau" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('annuler' ~ s.id) }}">
                            <button type="submit" class="btn btn--sm btn--danger">Annuler</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
