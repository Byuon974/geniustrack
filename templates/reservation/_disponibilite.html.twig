{# Créneaux du jour pour une durée donnée, en LISTE verticale épurée (style
   agenda), groupés matin / après-midi. Chaque ligne : pastille d'état + heure +
   nombre de machines libres aligné à droite. Cliquer un créneau libre charge
   ses machines (contrôleur creneau-picker). Anonyme : aucun détail sur les
   réservations d'autrui. #}
{% set matin = [] %}
{% set aprem = [] %}
{% for c in creneaux %}
    {% if c.debut|date('H') < '12' %}
        {% set matin = matin|merge([c]) %}
    {% else %}
        {% set aprem = aprem|merge([c]) %}
    {% endif %}
{% endfor %}

{% if creneaux is empty %}
    <p class="cat">Aucun créneau ce jour pour cette durée.</p>
{% else %}
    {% for groupe in [{titre: 'Matin', liste: matin}, {titre: 'Après-midi', liste: aprem}] %}
        {% if groupe.liste is not empty %}
            <p class="fb-periode">{{ groupe.titre }}</p>
            <div class="fb-liste">
                {% for c in groupe.liste %}
                    {% if c.etat == 'complet' %}
                        <span class="fb-creneau fb-creneau--complet">
                            <span class="fb-pt"></span>
                            <span class="fb-heure">{{ c.heure }}</span>
                            <span class="fb-etat">Complet</span>
                        </span>
                    {% else %}
                        <button type="button"
                                class="fb-creneau fb-creneau--{{ c.etat }}"
                                data-creneau="{{ c.debut|date('Y-m-d\\TH:i') }}"
                                data-heure="{{ c.heure }}">
                            <span class="fb-pt"></span>
                            <span class="fb-heure">{{ c.heure }}</span>
                            <span class="fb-etat">{{ c.machinesLibres }} machine{{ c.machinesLibres > 1 ? 's' : '' }} libre{{ c.machinesLibres > 1 ? 's' : '' }}</span>
                        </button>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    {% endfor %}
{% endif %}
